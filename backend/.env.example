# ──────────────────────────────────────────────────────────
# AlphaAI Backend — Environment Variables
# Copy this to .env and fill in your real values
# ──────────────────────────────────────────────────────────

# ── App Settings ────────────────────────────────────────
APP_NAME=AlphaAI API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS Origins (comma-separated) ─────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Runtime / Performance ──────────────────────────────
REQUEST_TIMEOUT_SECONDS=10
CACHE_TTL_SECONDS=300

# ── API Keys ────────────────────────────────────────────
# Get your free key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ── Supabase (optional, required for auth integration) ─────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE=service-role-key

# ── AI Models & Inference ─────────────────────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Fallback AI models (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

SENTIMENT_MODEL=ProsusAI/finbert